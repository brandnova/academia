DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=yourapp.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://yourapp.pythonanywhere.com
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Database. Preferred: a single DATABASE_URL (most hosted Postgres providers
# give you one, often with ?sslmode=require appended). If unset, the
# discrete DATABASE_* vars below are used instead.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# Fallback to discrete vars if DATABASE_URL is not set. You can leave these
# blank if you are using DATABASE_URL.
DATABASE_NAME=academia_db
DATABASE_USER=academia_user
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=60

# Cache. Leave REDIS_URL unset to fall back to local in-memory caching
# automatically, no code change needed either way.
REDIS_URL=redis://default:password@your-redis-host:6379/0
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_SEARCH=30

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Academia <no-reply@academia.local>

